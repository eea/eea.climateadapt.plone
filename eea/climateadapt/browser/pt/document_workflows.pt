<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="en"
      lang="en"
      metal:use-macro="context/main_template/macros/master"
      i18n:domain="eea.climateadapt">
<body>

<metal:main fill-slot="main">
    <h1>Workflow and Content Type Documentation</h1>

    <div id="content-core">
        <h2>Content Type to Workflow Mapping</h2>
        <table class="listing">
            <thead>
                <tr>
                    <th>Content Type</th>
                    <th>Workflow(s)</th>
                </tr>
            </thead>
            <tbody>
                <tr tal:repeat="type_id python:sorted(view.data['type_to_workflow'].keys())">
                    <td tal:content="type_id">News Item</td>
                    <td>
                        <ul tal:define="workflows python:view.data['type_to_workflow'][type_id]"
                            tal:condition="workflows">
                            <li tal:repeat="wf_id workflows" tal:content="wf_id">news_workflow</li>
                        </ul>
                        <span tal:condition="not:python:view.data['type_to_workflow'][type_id]">(no workflow)</span>
                    </td>
                </tr>
            </tbody>
        </table>

        <h2>Workflow Definitions</h2>
        <div tal:repeat="wf_id python:sorted(view.data['workflow_definitions'].keys())"
             style="margin-bottom: 2em; border-bottom: 1px solid #ccc; padding-bottom: 1em;">
            <tal:block tal:define="info python:view.data['workflow_definitions'][wf_id]">
                <h3 tal:content="python:'Workflow: ' + wf_id + ' (' + info['title'] + ')'">Workflow ID</h3>
                <p><strong>Initial State:</strong> <span tal:content="info/initial_state">private</span></p>

                <div tal:condition="info/states">
                    <h4>States</h4>
                    <ul>
                        <li tal:repeat="s_id python:sorted(info['states'].keys())">
                            <tal:block tal:define="s_info python:info['states'][s_id]">
                                <strong tal:content="s_id">private</strong> (<span tal:content="s_info/title">Private</span>)
                            </tal:block>
                        </li>
                    </ul>
                </div>

                <div tal:condition="info/transitions">
                    <h4>Transitions</h4>
                    <ul>
                        <li tal:repeat="t_id python:sorted(info['transitions'].keys())">
                            <tal:block tal:define="t_info python:info['transitions'][t_id]">
                                <strong tal:content="t_id">submit</strong> (<span tal:content="t_info/title">Submit</span>) 
                                &rarr; 
                                <span tal:content="python:t_info['new_state_id'] or '(remains in same state)'">pending</span>
                            </tal:block>
                        </li>
                    </ul>
                </div>
                
                <p tal:condition="python:info.get('note')" 
                   tal:content="python:info.get('note')" 
                   style="color: #666; font-style: italic;"></p>
            </tal:block>
        </div>
    </div>
</metal:main>

</body>
</html>
